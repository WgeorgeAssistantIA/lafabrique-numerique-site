# Formulaire de contact (app/api/contact/route.ts)
# Clé API Resend (sending_access suffit) — https://resend.com/api-keys
RESEND_API_KEY=

# Destinataire des demandes de devis (défaut : lafabriknumerique@outlook.com)
# CONTACT_TO=

# Expéditeur — le domaine doit être vérifié dans Resend
# (défaut : "La Fabrik Numérique <contact@lafabriknumerique.fr>")
# CONTACT_FROM=
